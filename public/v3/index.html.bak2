<!-- ============================================================
     PAGE-LOAD INTRO — logo reveal + curtain wipe (first paint).
     ============================================================ -->
<script>
(function () {
  var d = document, root = d.documentElement;
  var SEEN = "ap_intro_seen_v1";
  var reduce = false;
  try { reduce = matchMedia("(prefers-reduced-motion: reduce)").matches; } catch (e) {}
  var seen = false;
  try { seen = sessionStorage.getItem(SEEN) === "1"; } catch (e) {}
  try { sessionStorage.setItem(SEEN, "1"); } catch (e) {}
  /* play the FULL intro on every load (no seen-skip) — animation then reveal */
  if (!reduce) root.classList.add("intro-active");   /* hold hero reveals hidden until the intro ends */
  function teardown() {
    root.classList.remove("intro-active");           /* -> hero animates IN as the intro clears */
    var el = d.querySelector("[data-intro]");
    if (!el) return;
    el.setAttribute("hidden", "");
    el.parentNode && el.parentNode.removeChild(el);
  }
  var done = reduce ? 720 : 2120;
  function schedule() { setTimeout(teardown, done); }
  if (d.readyState === "loading") {
    d.addEventListener("DOMContentLoaded", schedule, { once: true });
  } else { schedule(); }
  addEventListener("load", function () { setTimeout(teardown, 2300); }, { once: true });
})();
</script>
<div class="intro" data-intro aria-hidden="true">
  <div class="intro__stage">
    <span class="intro__glow" aria-hidden="true"></span>
    <svg class="intro__logo" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <g class="intro__strokes" fill="none" stroke="currentColor" stroke-width="10" stroke-linecap="round" stroke-linejoin="round">
        <polyline class="intro__draw" points="58,72 37,100 58,128"/>
        <polyline class="intro__draw" points="146,72 167,100 146,128"/>
        <line class="intro__draw intro__draw--slash" x1="131" y1="68" x2="116" y2="132"/>
      </g>
      <g class="intro__glyphs" fill="currentColor">
        <path class="intro__glyph" d="M72 130 L85 70 L93 70 L106 130 L96.5 130 L93.6 116 L84.4 116 L81.5 130 Z M86.1 104 L91.9 104 L89 89.8 Z"/>
        <path class="intro__glyph" d="M107 70 L122 70 C133 70 139.5 77.5 139.5 88 C139.5 98.5 133 106 122 106 L116 106 L116 130 L107 130 Z M116 78.2 L116 97.8 L121 97.8 C126.6 97.8 130 94 130 88 C130 82 126.6 78.2 121 78.2 Z"/>
      </g>
    </svg>
    <span class="intro__wordmark" aria-hidden="true">ABHIJIT&nbsp;PRAMANIK</span>
    <span class="intro__hairline" aria-hidden="true"></span>
    <p class="intro__welcome" aria-hidden="true">Welcome to my <em>world</em>.</p>
  </div>
</div>

<!-- ============================================================
     ANIMATED BACKGROUND LAYER
     <canvas> is painted by the JS engine (drifting violet + lime
     aurora blooms over a deep-indigo base). It sits behind ALL
     content. A STATIC gradient fallback is painted by CSS on the
     same element's parent so the page is gorgeous even before /
     without JS, on mobile, and under prefers-reduced-motion.
     ============================================================ -->
<div class="bg" aria-hidden="true">
  <canvas id="bg-canvas" class="bg__canvas"></canvas>
  <div class="bg__grain"></div>
  <div class="bg__vignette"></div>
</div>

<!-- Custom cursor (desktop / pointer:fine only — JS positions it) -->
<div class="cursor" data-cursor aria-hidden="true">
  <span class="cursor__dot"></span>
  <span class="cursor__ring"></span>
</div>

<!-- Scroll progress bar (JS sets --scroll 0..1) -->
<div class="scroll-progress" data-scroll-progress aria-hidden="true"></div>

