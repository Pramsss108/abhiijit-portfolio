<!-- ============================================================
     MERGED PROOF / RESULTS SECTION
     Host keeps id="proof-numbers" (preserves count-up + ribbon CSS + any #proof-numbers anchor).
     Extra class .proof-merged scopes the money-green numerals + spacing below.
     Replaces old #proof-numbers; #clients and #proof are deleted.
     ============================================================ -->
<section id="proof-numbers" class="section section--tint stats-marquees proof proof-merged" aria-labelledby="stats-marquees-title">
  <div class="container">
    <header class="section__head section__head--center reveal">
