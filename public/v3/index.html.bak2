<section class="section process-faq" id="process" aria-labelledby="process-title">
  <div class="container">

    <div class="process" data-pin>
      <div class="section__head section__head--center reveal">
        <p class="eyebrow eyebrow--center">How I work</p>
        <h2 class="section__title" id="process-title">A <span class="text-grad">proof-driven</span> process</h2>
        <p class="section__lead">Every engagement runs through the same six steps — so the result is never a guess. It is documented, measured, and verifiable.</p>
      </div>

      <div class="process__grid">
        <div class="process__rail" aria-hidden="true">
          <div class="progress-line">
            <div class="progress-line__fill"></div>
          </div>
        </div>

        <ol class="process__steps">
          <li class="process__step reveal" data-step="1">
            <span class="process__node"><span class="process__num">01</span></span>
            <div class="process__body card process__card">
              <h3 class="process__title">Understand the target</h3>
              <p class="process__desc">I learn the business, the audience, and what "growth" actually means for you before touching a keyword.</p>
            </div>
          </li>
          <li class="process__step reveal" data-step="2">
            <span class="process__node"><span class="process__num">02</span></span>
            <div class="process__body card process__card">
              <h3 class="process__title">Research keywords &amp; proof</h3>
              <p class="process__desc">SEMrush, Ubersuggest and RankMath map the real opportunities — and the evidence to back them.</p>
            </div>
          </li>
          <li class="process__step reveal" data-step="3">
            <span class="process__node"><span class="process__num">03</span></span>
            <div class="process__body card process__card">
              <h3 class="process__title">Build the content system</h3>
              <p class="process__desc">Briefs, structure, and SEO-ready content built to scale — not one-off posts that fade.</p>
            </div>
          </li>
          <li class="process__step reveal" data-step="4">
            <span class="process__node"><span class="process__num">04</span></span>
            <div class="process__body card process__card">
              <h3 class="process__title">Publish &amp; organize</h3>
              <p class="process__desc">Clean WordPress publishing, internal linking, and a structure that stays maintainable.</p>
            </div>
          </li>
          <li class="process__step reveal" data-step="5">
            <span class="process__node"><span class="process__num">05</span></span>
            <div class="process__body card process__card">
              <h3 class="process__title">Measure &amp; improve</h3>
              <p class="process__desc">Google Analytics and Meta Business Suite track what works, so the next move is informed.</p>
            </div>
          </li>
          <li class="process__step reveal" data-step="6">
            <span class="process__node"><span class="process__num">06</span></span>
            <div class="process__body card process__card">
              <h3 class="process__title">Document the proof</h3>
              <p class="process__desc">Results become proof cards — verifiable records, never invented testimonials.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>

    <div class="faq">
      <div class="section__head section__head--center reveal">
        <p class="eyebrow eyebrow--center">Questions</p>
        <h2 class="section__title">Things people <span class="text-lime">ask me</span></h2>
      </div>

      <div class="faq__list">
        <div class="faq__item card reveal">
          <h3 class="faq__heading">
            <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="faq-panel-1">
              <span class="faq__q">How long have you been doing this work?</span>
              <span class="faq__icon" aria-hidden="true"></span>
