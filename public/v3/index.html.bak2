<!-- TEMP hero editor: open localhost:5055/v3/?edit -> tune photo + DRAG cards + toggle Behind/Front -> Copy -> paste to Claude -->
<script>
(function(){
  if(!/[?&]edit/.test(location.search)) return;
  function init(){
    var photo=document.querySelector('.hero__photo--editorial'), halo=document.querySelector('.hero__halo');
    var core=document.querySelector('.hero__corehalo'), visual=document.querySelector('.hero__visual--editorial');
    var picEl=document.querySelector('.hero__pic');
    if(!photo||!visual) return;
    /* edit-mode: let pointer events reach cards even when they sit BEHIND the portrait */
    if(picEl) picEl.style.setProperty('pointer-events','none','important');
    /* keep Front/Behind tags hidden until a card is hovered (clean view) */
    var sEl=document.createElement('style'); sEl.textContent='.hero__metric [data-zbtn]{opacity:0;transition:opacity .15s} .hero__metric:hover [data-zbtn],.hero__metric:focus-within [data-zbtn]{opacity:1}'; document.head.appendChild(sEl);

    /* base = the baked rim + grounding shadows, so live preview matches production */
    var base='drop-shadow(0 0 13px rgba(255,198,88,0.42)) drop-shadow(0 0 30px rgba(245,176,62,0.26)) drop-shadow(0 34px 64px rgba(0,0,0,0.82))';
    /* sliders DEFAULT to the current baked NATURAL grade */
    var st={brightness:1.02,contrast:1.71,saturate:0.31,sepia:0.83,hue:0,glow:1,haloW:52};
    function applyPhoto(){
      photo.style.setProperty('filter','brightness('+st.brightness+') contrast('+st.contrast+') saturate('+st.saturate+') sepia('+st.sepia+') hue-rotate('+st.hue+'deg) '+base,'important');
      /* glow is now a full-cover layer — tune opacity only (size is fixed, edge-free) */
      if(halo){ halo.style.setProperty('opacity',st.glow,'important'); }
    }
    var rows=[['brightness','Brightness',0.4,1.8,0.01],['contrast','Contrast',0.5,2,0.01],['saturate','Saturate',0,2,0.01],['sepia','Warmth',0,1,0.01],['hue','Hue',-30,30,1],['glow','Glow opacity',0,1.3,0.01],['haloW','Glow size',30,90,1]];

    /* ---- card drag (POINTER events: mouse + touch + pen) + Behind/Front toggle ---- */
    var cards=[].slice.call(document.querySelectorAll('.hero__metric'));
    var cstate={};
    cards.forEach(function(card){
      var key=(card.className.match(/--(\w)/)||[,'?'])[1];
      var num=(card.querySelector('.hero__metric-num')||{}).textContent||key;
      cstate[key]={behind:false,num:num.trim()};
      card.style.setProperty('animation','none','important');     /* freeze idle float while editing */
      card.style.setProperty('pointer-events','auto','important');
      card.style.cursor='grab'; card.style.userSelect='none'; card.style.touchAction='none';
      /* z-toggle tag (large enough to tap) */
      var zb=document.createElement('button');
      zb.textContent='Front'; zb.setAttribute('data-zbtn','1');
      zb.style.cssText='position:absolute;top:-13px;left:-13px;z-index:99999;font:10px/1 system-ui,sans-serif;background:#d8a73e;color:#07090d;border:0;border-radius:7px;padding:5px 9px;cursor:pointer;font-weight:700;touch-action:manipulation;box-shadow:0 4px 12px rgba(0,0,0,.5)';
      zb.addEventListener('pointerdown',function(e){e.stopPropagation();});
      zb.addEventListener('click',function(e){e.stopPropagation(); e.preventDefault();
        cstate[key].behind=!cstate[key].behind;
        card.style.setProperty('z-index',cstate[key].behind?'2':'6','important');
        card.style.setProperty('outline',cstate[key].behind?'1px dashed rgba(245,186,74,.7)':'none','important');
        card.style.setProperty('outline-offset','3px','important');
        zb.textContent=cstate[key].behind?'Behind':'Front';
        zb.style.background=cstate[key].behind?'#566':'#d8a73e'; zb.style.color=cstate[key].behind?'#fff':'#07090d';
        updateOut();
      });
      card.appendChild(zb);
      /* drag */
      card.addEventListener('pointerdown',function(e){
        if(e.target&&e.target.getAttribute&&e.target.getAttribute('data-zbtn'))return;
        e.preventDefault();
        var cr=card.getBoundingClientRect();
        var offX=e.clientX-cr.left, offY=e.clientY-cr.top;
        try{card.setPointerCapture(e.pointerId);}catch(_){}
        card.style.cursor='grabbing';
        function mv(ev){
          var vr=visual.getBoundingClientRect(); /* recompute each move = robust to scroll/parallax */
          card.style.setProperty('left',Math.round(ev.clientX-vr.left-offX)+'px','important');
          card.style.setProperty('top',Math.round(ev.clientY-vr.top-offY)+'px','important');
          card.style.setProperty('right','auto','important');
          card.style.setProperty('bottom','auto','important');
          updateOut();
        }
        function up(){ try{card.releasePointerCapture(e.pointerId);}catch(_){}
          card.removeEventListener('pointermove',mv); card.removeEventListener('pointerup',up); card.removeEventListener('pointercancel',up); card.style.cursor='grab'; }
        card.addEventListener('pointermove',mv); card.addEventListener('pointerup',up); card.addEventListener('pointercancel',up);
      });
    });

    /* ---- panel (draggable by header, collapsible) ---- */
    var p=document.createElement('div');
    p.style.cssText='position:fixed;right:14px;bottom:14px;z-index:100000;width:256px;max-height:92vh;overflow:auto;background:rgba(10,12,16,.97);border:1px solid rgba(216,167,62,.45);border-radius:14px;padding:0 14px 14px;font:12px/1.5 system-ui,sans-serif;color:#f5f2ea;box-shadow:0 22px 54px rgba(0,0,0,.7)';
    var h='<div id="hdr" style="display:flex;align-items:center;justify-content:space-between;margin:0 -14px 8px;padding:10px 12px;cursor:move;background:rgba(216,167,62,.1);border-bottom:1px solid rgba(216,167,62,.25);border-radius:14px 14px 0 0;touch-action:none">'+
      '<span style="font-weight:700;color:#f1c45a">⠿ Hero Editor</span><button id="min" style="background:transparent;border:0;color:#f1c45a;font-size:16px;cursor:pointer;line-height:1">–</button></div>'+
      '<div id="body"><div style="color:#8d8775;margin-bottom:8px;font-size:11px">Drag header to move me. DRAG cards anywhere · tap a card’s <b style="color:#d8a73e">Front/Behind</b> tag · Copy → paste to Claude.</div>';
    rows.forEach(function(r){h+='<label style="display:block;margin:6px 0">'+r[1]+': <b id="v_'+r[0]+'">'+st[r[0]]+'</b><input type="range" id="s_'+r[0]+'" min="'+r[2]+'" max="'+r[3]+'" step="'+r[4]+'" value="'+st[r[0]]+'" style="width:100%;accent-color:#d8a73e"></label>';});
    h+='<button id="cp" style="width:100%;margin-top:8px;padding:9px;background:#d8a73e;color:#07090d;border:0;border-radius:8px;font-weight:700;cursor:pointer">Copy everything</button>';
    h+='<button id="rs" style="width:100%;margin-top:6px;padding:6px;background:transparent;color:#cdc7b8;border:1px solid rgba(255,255,255,.2);border-radius:8px;cursor:pointer">Reset photo</button>';
    h+='<div id="out" style="margin-top:8px;font:10px/1.4 monospace;color:#a89a78;word-break:break-all;white-space:pre-wrap"></div></div>';
    p.innerHTML=h; document.body.appendChild(p);
    rows.forEach(function(r){var s=p.querySelector('#s_'+r[0]),v=p.querySelector('#v_'+r[0]);s.addEventListener('input',function(){st[r[0]]=parseFloat(s.value);v.textContent=s.value;applyPhoto();updateOut();});});

    /* panel drag */
    var hdr=p.querySelector('#hdr');
    hdr.addEventListener('pointerdown',function(e){ if(e.target.id==='min')return; e.preventDefault();
      var pr=p.getBoundingClientRect(); var offX=e.clientX-pr.left, offY=e.clientY-pr.top;
      try{hdr.setPointerCapture(e.pointerId);}catch(_){}
      function mv(ev){ p.style.left=Math.round(ev.clientX-offX)+'px'; p.style.top=Math.round(ev.clientY-offY)+'px'; p.style.right='auto'; p.style.bottom='auto'; }
      function up(){ try{hdr.releasePointerCapture(e.pointerId);}catch(_){} hdr.removeEventListener('pointermove',mv); hdr.removeEventListener('pointerup',up); }
      hdr.addEventListener('pointermove',mv); hdr.addEventListener('pointerup',up);
    });
    /* collapse */
    var collapsed=false, bodyEl=p.querySelector('#body');
    p.querySelector('#min').addEventListener('click',function(e){e.stopPropagation(); collapsed=!collapsed; bodyEl.style.display=collapsed?'none':'block'; this.textContent=collapsed?'+':'–';});

    function cardLine(card){
      var key=(card.className.match(/--(\w)/)||[,'?'])[1];
      var vr=visual.getBoundingClientRect(), cr=card.getBoundingClientRect();
      var lx=cr.left-vr.left, ty=cr.top-vr.top;
      return 'CARD '+key+' ('+cstate[key].num+'): left '+(lx/vr.width*100).toFixed(1)+'% top '+(ty/vr.height*100).toFixed(1)+'%  ['+Math.round(lx)+'px,'+Math.round(ty)+'px]  '+(cstate[key].behind?'BEHIND':'FRONT');
    }
    function txt(){
      var t='PHOTO: brightness('+st.brightness+') contrast('+st.contrast+') saturate('+st.saturate+') sepia('+st.sepia+') hue-rotate('+st.hue+'deg)\nGLOW: opacity '+st.glow+' | size '+st.haloW+'vw\n';
      cards.forEach(function(c){t+=cardLine(c)+'\n';});
      return t;
    }
    function updateOut(){ p.querySelector('#out').textContent=txt(); }
    p.querySelector('#cp').addEventListener('click',function(){var t=txt();p.querySelector('#out').textContent=t;try{navigator.clipboard.writeText(t);}catch(e){}this.textContent='Copied ✓ send to Claude';var b=this;setTimeout(function(){b.textContent='Copy everything';},2500);});
    p.querySelector('#rs').addEventListener('click',function(){st={brightness:1.02,contrast:1.71,saturate:0.31,sepia:0.83,hue:0,glow:1,haloW:52};rows.forEach(function(r){p.querySelector('#s_'+r[0]).value=st[r[0]];p.querySelector('#v_'+r[0]).textContent=st[r[0]];});applyPhoto();updateOut();});

    applyPhoto(); updateOut();
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',init); else init();
})();
</script>

<!-- Mega-menu: keyboard / Escape / outside-click (hover + focus-within are pure CSS) -->
<script>
(function () {
  "use strict";
  var item = document.querySelector("[data-mega-item]");
  if (!item) return;
  var trigger = item.querySelector("[data-mega-trigger]");
  var panel = item.querySelector("[data-mega-panel]");
  if (!trigger || !panel) return;
  var mqFine = window.matchMedia ? window.matchMedia("(pointer: fine)") : null;
  function isTouch() { return !(mqFine && mqFine.matches); }
  function open() { panel.setAttribute("data-open", ""); trigger.setAttribute("aria-expanded", "true"); }
  function close() { panel.removeAttribute("data-open"); trigger.setAttribute("aria-expanded", "false"); }
  function isOpen() { return trigger.getAttribute("aria-expanded") === "true"; }
  trigger.addEventListener("click", function () {
    if (isTouch()) { if (!isOpen()) { open(); return; } window.location.hash = "skills"; close(); return; }
    window.location.hash = "skills";
  });
  trigger.addEventListener("keydown", function (e) {
    if (e.key === "ArrowDown") { e.preventDefault(); open(); var first = panel.querySelector("a"); if (first) first.focus(); }
  });
  item.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && isOpen()) { e.stopPropagation(); close(); trigger.focus(); }
  });
  document.addEventListener("click", function (e) { if (isOpen() && !item.contains(e.target)) close(); });
  item.addEventListener("focusout", function () {
    window.setTimeout(function () { if (!item.contains(document.activeElement)) close(); }, 0);
  });
})();
</script>

<!-- Hero rotating-skills pop-up + intro keyboard typewriter -->
<script>
(function(){
  var rm=false; try{ rm=matchMedia('(prefers-reduced-motion:reduce)').matches; }catch(e){}
  /* 1 · rotating "Specialising in [skill]" */
  var rail=document.querySelector('[data-rotator]');
  if(rail){
    var words=[].slice.call(rail.querySelectorAll('.hero__rword'));
    if(words.length>1 && !rm){
      var idx=0;
      setInterval(function(){
        var cur=words[idx]; cur.classList.remove('is-active'); cur.classList.add('is-out');
        setTimeout(function(){ cur.classList.remove('is-out'); }, 520);
        idx=(idx+1)%words.length;
        words[idx].classList.add('is-active');
      }, 2200);
    }
  }
  /* 2 · intro welcome line typed like a keyboard */
  var w=document.querySelector('.intro__welcome');
  if(w){
    var full='Welcome to my world.';
    if(rm){ /* leave the static italic line */ }
    else {
      w.textContent=''; w.classList.add('intro__welcome--type');
      var i=0;
      setTimeout(function tick(){
        if(i<=full.length){ w.textContent=full.slice(0,i); i++; setTimeout(tick, 42); }
        else { w.innerHTML='Welcome to my <em>world</em>.'; w.classList.add('intro__welcome--done'); }
      }, 820);
    }
  }
})();
</script>

<!-- Services horizontal carousel: drag-to-scroll + arrows -->
<script>
(function(){
  var grid=document.querySelector('.services__grid'); if(!grid) return;
  var wrap=grid.closest('.container') || grid.parentElement; wrap.style.position='relative';
  var down=false,startX=0,startScroll=0,moved=false;
  grid.addEventListener('pointerdown',function(e){ down=true; moved=false; startX=e.clientX; startScroll=grid.scrollLeft; try{grid.setPointerCapture(e.pointerId);}catch(_){} });
  grid.addEventListener('pointermove',function(e){ if(!down)return; var dx=e.clientX-startX; if(Math.abs(dx)>4){moved=true; grid.classList.add('is-dragging');} grid.scrollLeft=startScroll-dx; });
  function end(){ down=false; grid.classList.remove('is-dragging'); }
  grid.addEventListener('pointerup',end); grid.addEventListener('pointercancel',end);
  grid.addEventListener('click',function(e){ if(moved){ e.preventDefault(); e.stopPropagation(); } }, true);
  var IL='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>';
  var IR='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>';
  function mk(cls,label,icon){ var b=document.createElement('button'); b.type='button'; b.className='svc-arrow '+cls; b.setAttribute('aria-label',label); b.innerHTML=icon; wrap.appendChild(b); return b; }
  var prev=mk('svc-arrow--prev','Previous services',IL), next=mk('svc-arrow--next','Next services',IR);
  function step(){ return Math.min(grid.clientWidth*0.85, 350); }
  prev.addEventListener('click',function(){ grid.scrollBy({left:-step(),behavior:'smooth'}); });
  next.addEventListener('click',function(){ grid.scrollBy({left:step(),behavior:'smooth'}); });
  function upd(){ prev.disabled=grid.scrollLeft<=2; next.disabled=grid.scrollLeft>=grid.scrollWidth-grid.clientWidth-2; }
  grid.addEventListener('scroll',upd,{passive:true}); window.addEventListener('resize',upd); setTimeout(upd,100);
})();
</script>

<!-- Custom cursor: gold dot + lagging ring (fine-pointer + motion-allowed only) -->
<script>
(function(){
  try{
    if(!matchMedia('(pointer:fine)').matches || matchMedia('(prefers-reduced-motion:reduce)').matches) return;
  }catch(e){ return; }
  var root=document.documentElement;
  var dot=document.createElement('span'); dot.className='ap-cursor__dot'; dot.setAttribute('aria-hidden','true');
  var ring=document.createElement('span'); ring.className='ap-cursor__ring'; ring.setAttribute('aria-hidden','true');
  document.body.appendChild(dot); document.body.appendChild(ring);
  root.classList.add('ap-cursor-on');
  var mx=innerWidth/2, my=innerHeight/2, rx=mx, ry=my;
  addEventListener('mousemove',function(e){ mx=e.clientX; my=e.clientY; dot.style.left=mx+'px'; dot.style.top=my+'px'; },{passive:true});
  (function loop(){ rx+=(mx-rx)*0.18; ry+=(my-ry)*0.18; ring.style.left=rx+'px'; ring.style.top=ry+'px'; requestAnimationFrame(loop); })();
  var HOVER='a,button,[data-magnetic],[data-mega-trigger],.card,.service-card,.expertise-card,.proof-client,.svc-arrow,input,textarea,select,[role="button"],label';
  addEventListener('mouseover',function(e){ if(e.target.closest&&e.target.closest(HOVER)) root.classList.add('ap-cursor-hover'); },{passive:true});
  addEventListener('mouseout',function(e){ if(e.target.closest&&e.target.closest(HOVER)) root.classList.remove('ap-cursor-hover'); },{passive:true});
  addEventListener('mousedown',function(){ root.classList.add('ap-cursor-down'); },{passive:true});
  addEventListener('mouseup',function(){ root.classList.remove('ap-cursor-down'); },{passive:true});
  document.addEventListener('mouseleave',function(){ dot.style.opacity='0'; ring.style.opacity='0'; });
  document.addEventListener('mouseenter',function(){ dot.style.opacity=''; ring.style.opacity=''; });
})();
</script>
</body>
</html>
