        <span class="stats-bar__glow" aria-hidden="true"></span>
        <span class="stat__num" data-count="5" data-suffix="+">5+</span>
        <span class="stat__label">Years of Proof</span>
      </li>
    </ul>
  </div>

  <!-- (B) RIBBONS — kept as the divider between the numbers and the receipts -->
  <div class="marquees reveal reveal--delay-2" aria-hidden="true">
    <div class="marquee marquee--skills" data-label="Disciplines" style="--marquee-dur:38s">
      <div class="marquee__track">
        <span class="marquee__item">SEO Strategy</span><span class="marquee__sep">•</span>
