<!-- ============================================================
     WORK — signature PINNED-SCROLL architecture.
     Desktop (>=1024px): the left .work__lede pins (position:sticky)
     while the right .work__stream scrolls past. A lightweight IO
     (initWorkPin in app.js) flips data-active on the lede + each
     item so the narrative copy + index update per item in view.
     Mobile / no-JS / reduced-motion: it is a plain stacked section
     (sticky neutralised) — fully readable, zero pinning, no jank.
     Real screenshots drop straight into .screen__shot img later.
     ============================================================ -->
<section class="section showcase work" id="work" data-work aria-labelledby="showcase-title">
  <div class="container work__layout">

    <!-- LEFT: sticky narrative — pins on desktop, leads the section -->
    <div class="work__lede" data-work-lede>
      <p class="eyebrow reveal">Selected Work</p>
      <h2 class="section__title work__title reveal reveal--delay-1" id="showcase-title" data-split="words">
        Proof-Backed <span class="text-grad">Work</span>
      </h2>

      <!-- Per-item narrative: only the [data-active] panel is shown.
           initWorkPin swaps active as each .work-item enters view. -->
      <div class="work__narr reveal reveal--delay-2" aria-live="polite">
        <p class="work__narr-panel is-active" data-narr="0">
          Real engagements, not mockups — SEO growth across <strong>36+ companies</strong> in
          India, Dubai & the USA, with <strong>400+ articles</strong> published and rankings
          I can point to. Scroll to walk the work.
        </p>
        <p class="work__narr-panel" data-narr="1">
          <strong>400+ SEO articles</strong> structured for intent and conversion, published clean
          on WordPress & Wix — internal linking, on-page, and a CMS workflow built to scale.
        </p>
        <p class="work__narr-panel" data-narr="2">
          <strong>Bongbari</strong> — my own Instagram page, <strong>3M+ views</strong>. Virality
          decoded, not luck: short-form editing, hooks, and a repeatable content system.
        </p>
        <p class="work__narr-panel" data-narr="3">
          Analytics, AI & no-code workflows that turn the busywork into output — GA4 + Meta Suite
          reporting that translates numbers into the next decision.
        </p>
      </div>

      <!-- Live progress: which item of N is in view -->
      <div class="work__meta reveal reveal--delay-3" aria-hidden="true">
        <span class="work__count"><span data-work-current>01</span> · <span data-work-total>04</span></span>
        <span class="work__progress"><span class="work__progress-fill" data-work-progress></span></span>
      </div>

      <div class="work__cta reveal reveal--delay-3">
        <a class="btn btn--gold-ghost" href="#contact" data-magnetic>Start a project</a>
        <a class="btn btn--gold-ghost work__cta-ig" href="https://www.instagram.com/bongbari" target="_blank" rel="noopener" data-magnetic>
          Bongbari · 3M+ ↗
        </a>
      </div>
    </div>

    <!-- RIGHT: the scrolling stream of real work items -->
    <ol class="work__stream" data-work-stream role="list">

      <!-- Item 01 — SEO -->
      <li class="work-item reveal" id="work-1" data-work-item data-narr-target="0">
        <article class="card work-item__card" data-tilt>
          <div class="work-item__head">
            <span class="work-item__idx" aria-hidden="true">01</span>
            <div class="work-item__heading">
              <h3 class="work-item__title">SEO Growth & Rank Tracking</h3>
              <p class="work-item__kicker">Across 36+ companies · India · Dubai · USA</p>
            </div>
          </div>
          <div class="screen work-item__screen">
            <div class="screen__frame">
              <span class="screen__dots" aria-hidden="true"><i></i><i></i><i></i></span>
              <div class="screen__shot">
                <img src="/images/hero_seo_3d.jpg" alt="SEO rank-tracking dashboard with keyword positions trending upward" loading="lazy" decoding="async" width="900" height="600">
              </div>
              <div class="screen__glow" aria-hidden="true"></div>
            </div>
          </div>
          <p class="work-item__desc">Technical audits, keyword maps and rank tracking that turn search into a documented growth channel — measured in SEMrush & RankMath, not promised.</p>
          <ul class="chip-row work-item__chips" role="list">
            <li class="chip chip--lime">SEMrush</li>
            <li class="chip">RankMath</li>
            <li class="chip">Keyword Strategy</li>
          </ul>
        </article>
      </li>

      <!-- Item 02 — Content / WordPress -->
      <li class="work-item reveal" id="work-2" data-work-item data-narr-target="1">
        <article class="card work-item__card" data-tilt>
          <div class="work-item__head">
            <span class="work-item__idx" aria-hidden="true">02</span>
            <div class="work-item__heading">
              <h3 class="work-item__title">Content System & WordPress</h3>
              <p class="work-item__kicker">400+ articles published · WordPress & Wix</p>
            </div>
          </div>
          <div class="screen work-item__screen">
            <div class="screen__frame">
              <span class="screen__dots" aria-hidden="true"><i></i><i></i><i></i></span>
              <div class="screen__shot">
                <img src="/images/hero_wordpress_3d.jpg" alt="WordPress content publishing workspace with structured posts and pages" loading="lazy" decoding="async" width="900" height="600">
              </div>
              <div class="screen__glow" aria-hidden="true"></div>
            </div>
          </div>
          <p class="work-item__desc">SEO content that reads like a human and ranks like a machine — briefed, structured and published clean on WordPress with internal linking that compounds.</p>
          <ul class="chip-row work-item__chips" role="list">
            <li class="chip chip--violet">WordPress</li>
            <li class="chip">SEO Copy</li>
            <li class="chip">CMS Workflow</li>
