        <span class="marquee__item">Video Editing</span><span class="marquee__sep">•</span>
        <span class="marquee__item">Analytics</span><span class="marquee__sep">•</span>
        <span class="marquee__item">No-Code Builds</span><span class="marquee__sep">•</span>
        <span class="marquee__item">Canva Design</span><span class="marquee__sep">•</span>
        <span class="marquee__item">Copywriting</span><span class="marquee__sep">•</span>
        <span class="marquee__item">SEO Strategy</span><span class="marquee__sep">•</span>
