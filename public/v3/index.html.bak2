<!-- Progressive-enhancement flag: scopes the reveal-hide rule to html.js so the
     page is NEVER permanently blank if JS is disabled or fails to load. -->
<script>document.documentElement.classList.add('js');</script>

<!-- Page-load intro: critical CSS so the curtain is opaque from the FIRST paint (no FOUC) -->
<style>
  .intro{position:fixed;inset:0;z-index:9999;background:#07090d;}
  .intro-skip .intro,.intro-skip .intro *{animation:none!important;}
  .intro-skip .intro__draw{stroke-dashoffset:0!important;}
  .intro-skip .intro__glyph,.intro-skip .intro__wordmark{opacity:1!important;transform:none!important;}
</style>

<!-- Design system -->
<link rel="stylesheet" href="styles.css" />

<!-- Structured data: Person -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Abhijit Pramanik",
  "jobTitle": "SEO, Content & WordPress Specialist",
  "url": "https://abhijit.works/",
