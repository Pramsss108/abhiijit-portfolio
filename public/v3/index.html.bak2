            <li class="chip chip--gold"><a href="https://www.instagram.com/bongbari" target="_blank" rel="noopener" aria-label="Bongbari — my Instagram, 3M+ views">View Bongbari ↗</a></li>
          </ul>
        </article>
      </li>

      <!-- Item 04 — Analytics / AI -->
      <li class="work-item reveal" id="work-4" data-work-item data-narr-target="3">
